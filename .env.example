# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://sensu:yourpassword@postgres:5432/sensu_pay

# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────
# Secret key used to sign JWT access and refresh tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-strong-random-key

# ─────────────────────────────────────────────
# LocTube MQTT (device real-time events)
# ─────────────────────────────────────────────
# MQTT broker hostname provided by LocTube/EVMars.
EVIEW_MQTT_HOST=your-mqtt-broker.example.com

# MQTT broker port (LocTube default: 38005).
EVIEW_MQTT_PORT=38005

# MQTT credentials from your LocTube account.
EVIEW_MQTT_USERNAME=your-mqtt-username
EVIEW_MQTT_PASSWORD=your-mqtt-password

# MQTT client ID — must be unique per connection. Format: <anything>||sensu
EVIEW_MQTT_CLIENT_ID=sensu-api||sensu

# LocTube product ID assigned to your account (e.g. MX037).
EVIEW_PRODUCT_ID=MX037

# Set to "false" to start the API without connecting to MQTT (useful for local dev).
EVIEW_MQTT_AUTO_START=true

# ─────────────────────────────────────────────
# EVMars REST API (device config: geofences, contacts, battery, etc.)
# ─────────────────────────────────────────────
# Base URL for the LocTube/EVMars REST API.
EVMARS_API_URL=https://api.evmars.com

# EVMars API client ID from your account dashboard.
EVMARS_CLIENT_ID=your-evmars-client-id

# EVMars API secure key from your account dashboard.
EVMARS_SECURE_KEY=your-evmars-secure-key

# ─────────────────────────────────────────────
# Cloudinary (profile image upload)
# ─────────────────────────────────────────────
# Obtain from https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─────────────────────────────────────────────
# AWS (device command queue)
# ─────────────────────────────────────────────
# SQS queue URL for sending commands to devices.
DEVICE_COMMAND_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/your-account-id/your-queue-name

# AWS region where SQS queue is hosted.
AWS_DEFAULT_REGION=us-east-1

# ─────────────────────────────────────────────
# CORS (optional — defaults shown below)
# ─────────────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to the three Sensu domains
# plus localhost:8081 if this variable is not set.
# CORS_ALLOW_ORIGINS=https://pay.sensu.com.mx,https://api.sensu.com.mx,https://sensu.com.mx

# ─────────────────────────────────────────────
# Sentry (error tracking — optional)
# ─────────────────────────────────────────────
# DSN from your Sentry project settings. Leave empty to disable.
# SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
# SENTRY_ENVIRONMENT=production
